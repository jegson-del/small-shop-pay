# Copy this file to .env and set your backend URL for development.
# Required when testing on a physical device (Expo Go): use your PC's LAN IP.
# Get your IP: Windows: ipconfig | Mac/Linux: ifconfig or ip addr

# LARAGON: Laragon uses port 80 (no port in URL). Use your PC IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.146/api
# If using "php artisan serve" instead, use --host=0.0.0.0 and port 8000:
# EXPO_PUBLIC_API_URL=http://192.168.1.146:8000/api

# Examples (replace 192.168.1.146 with your IP):
EXPO_PUBLIC_API_URL=http://192.168.1.146/api
# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2/api
# iOS simulator (localhost):
# EXPO_PUBLIC_API_URL=http://localhost/api
